{
  "awsAuthRefresh": "aws sso login --profile code-assist-admin",
  "env": {
    "AWS_REGION": "eu-west-1",
    "AWS_PROFILE": "code-assist-admin",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "ANTHROPIC_MODEL": "global.anthropic.claude-sonnet-5"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "mcp__plugin_playwright_playwright__*",
      "mcp__plugin_context7_context7__*"
    ]
  },
  "model": "eu.anthropic.claude-opus-4-8[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cbosle/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "pm-toolkit@pm-skills": true,
    "pm-product-strategy@pm-skills": true,
    "pm-product-discovery@pm-skills": true,
    "pm-market-research@pm-skills": true,
    "pm-data-analytics@pm-skills": true,
    "pm-marketing-growth@pm-skills": true,
    "pm-go-to-market@pm-skills": true,
    "pm-execution@pm-skills": true,
    "iac-terraform@devops-skills": true,
    "k8s-troubleshooter@devops-skills": true,
    "monitoring-observability@devops-skills": true,
    "linear@claude-plugins-official": true,
    "python-development@claude-code-workflows": true,
    "backend-development@claude-code-workflows": true,
    "kubernetes-operations@claude-code-workflows": true,
    "cloud-infrastructure@claude-code-workflows": true,
    "full-stack-orchestration@claude-code-workflows": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "aws-cost-optimization@devops-skills": true,
    "ci-cd@devops-skills": true,
    "gitops-workflows@devops-skills": true,
    "frontend-design@claude-code-plugins": true,
    "hookify@claude-code-plugins": false,
    "learning-output-style@claude-code-plugins": true,
    "plugin-dev@claude-code-plugins": true,
    "pr-review-toolkit@claude-code-plugins": true,
    "ralph-wiggum@claude-code-plugins": true,
    "security-guidance@claude-code-plugins": true,
    "gitlab@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "ponytail@ponytail": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "pm-skills": {
      "source": {
        "source": "github",
        "repo": "phuryn/pm-skills"
      }
    },
    "devops-skills": {
      "source": {
        "source": "git",
        "url": "https://github.com/ahmedasmar/devops-claude-skills.git"
      }
    },
    "claude-code-workflows": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "theme": "auto"
}
