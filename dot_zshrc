# bun completions
[ -s "/home/cbosle/.bun/_bun" ] && source "/home/cbosle/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# kubernetes
alias kubectl="kubecolor"      # colorized kubectl output
alias k="kubecolor"            # k get pods
compdef kubecolor=kubectl      # keep kubectl completion under kubecolor
compdef k=kubectl              # ...and under k
alias ktx="kubectx"            # ktx <context> to switch cluster/context
alias kns="kubens"             # kns <namespace> to switch namespace

# modern cli replacements
alias ls='eza --group-directories-first'
alias ll='eza -lah --group-directories-first --git'
alias lt='eza --tree --level=2'
alias cat='bat --paging=never'        # optional; use `command cat` for raw
eval "$(zoxide init zsh)"             # adds the `z` command (smart cd)export PATH="$HOME/.local/bin:$PATH"

# Secrets live in an untracked file (not managed by chezmoi)
[ -f ~/.config/zsh/secrets.zsh ] && source ~/.config/zsh/secrets.zsh
