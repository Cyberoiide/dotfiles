# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set theme to powerlevel10k
ZSH_THEME="powerlevel10k/powerlevel10k"

# Plugins configuration
# From the article: zsh-autosuggestions, zsh-syntax-highlighting, and built-in plugins
plugins=(
  git
  docker
  docker-compose
  kubectl
  npm
  node
  python
  pip
  terraform
  ansible
  history
  sudo
  command-not-found
  colored-man-pages
  zsh-autosuggestions
  zsh-syntax-highlighting
)

source $ZSH/oh-my-zsh.sh

