  export GITLAB_ACCESS_TOKEN="$HEKA_GITLAB_TOKEN"
  export GITLAB_TOKEN="$HEKA_GITLAB_TOKEN"
  export GITLAB_USERNAME="clement.bosle"
}

stratumngit () {
  export GITLAB_HOST="git.sia.partners"
  export GITLAB_URL="https://git.sia.partners"
  export GITLAB_BASE_URL="https://git.sia.partners/api/v4"
  export GITLAB_USERNAME="clement.bosle"
  export GITLAB_TOKEN="$STRATUMN_GITLAB_TOKEN"
  export GITLAB_ACCESS_TOKEN="$STRATUMN_GITLAB_TOKEN"
}

gitlab () {
    case "$1" in
        strat|stratumn)
            stratumngit && glab auth login --hostname git.sia.partners --stdin <<< "$GITLAB_TOKEN"
            ;;
        heka)
            hekagit && glab auth login --hostname git.sia-partners.com --stdin <<< "$GITLAB_TOKEN"
            ;;
        *)
            echo "Usage: gitlab {strat|stratumn|heka}" >&2
            return 1
            ;;
    esac
}

setup-helm () { # setup-helm prefix-dev heka or setup-helm stratumn-staging stratumn
    export AWS_PROFILE="$1"
    export AWS_REGION="eu-west-1"

    case "$2" in
        strat|stratumn)
            gitlab stratumn
            export CI_API_V4_URL="https://git.sia.partners/api/v4"
            ;;
        heka)
            gitlab heka
            export CI_API_V4_URL="https://git.sia-partners.com/api/v4"
            ;;
        *)
            echo "configured for gitlab {strat|stratumn|heka}" >&2
            return 1
            ;;
    esac
}

getme () {
    case "$1" in
        strat|stratumn)
            aws sso login --sso-session stratumn
            ;;
        heka)
            aws sso login --sso-session heka
            ;;
        *)
            echo "using aws sso for {strat|stratumn|heka}" >&2
            return 1
            ;;
    esac
}

