bastion-sia() {                # tunnel to sia-common-tooling bastion (frees :8888, then ktx sia-common-tooling)
  pkill -f 'ssh.*-L8888:localhost:8888' 2>/dev/null
  gcloud beta compute ssh common-tooling-bastion --project=sia-devops --zone=europe-west1-b -- -4 -L8888:localhost:8888 -N -f
}
bastion-ctx() {                # tunnel to cetautomatix bastion via SSM (frees :1234, then ktx ctx)
  pkill -f 'ssm start-session.*localPortNumber.*1234' 2>/dev/null
  local id=$(aws autoscaling describe-auto-scaling-groups \
    --region eu-west-1 --profile stratumn-monitoring \
    --auto-scaling-group-names ctx-bastion-asg \
    --query 'AutoScalingGroups[0].Instances[0].InstanceId' --output text)
  [ -z "$id" ] || [ "$id" = "None" ] && { echo "no bastion instance found (sso expired? run: aws sso login --profile stratumn-monitoring)"; return 1; }
  aws ssm start-session --target "$id" \
    --document-name AWS-StartPortForwardingSession \
    --parameters '{"portNumber":["3128"],"localPortNumber":["1234"]}' \
    --region eu-west-1 --profile stratumn-monitoring >/dev/null 2>&1 &
  echo "tunnel starting on :1234 (bastion $id)"
}

