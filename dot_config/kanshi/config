# kanshi dynamic output profiles. First profile whose outputs exactly
# match the connected set wins. Identify monitors: swaymsg -t get_outputs

# HOME: Acer (left) + Asus (center, primary) + laptop (right)
profile home {
    output "Acer Technologies VG240Y S 21250111E3E00" mode 1920x1080 position 0,0 enable
    output "ASUSTek COMPUTER INC PA278QV SCLMQS015413" mode 2560x1440 position 1920,0 enable
    output eDP-1 mode 1920x1200 position 4480,0 enable
    exec ~/.azotebg
}

# WORK: LG BL650 on DP-1 top, laptop below.
profile work {
    output DP-1 mode 1920x1080 position 0,0 enable
    output eDP-1 mode 1920x1200 position 0,1080 enable
    exec ~/.azotebg
}

# NOMAD: laptop only, undocked.
profile nomad {
    output eDP-1 mode 1920x1200 position 0,0 enable
    exec ~/.azotebg
}
